# ── GCP Configuration ────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name
GCS_CHECKPOINT_PATH=gs://your-bucket/checkpoints
GCS_BRONZE_PATH=gs://your-bucket/bronze/crypto

# ── Authentication — choose ONE option ───────────────────────────────────────
# Option A (recommended for local dev): run "gcloud auth application-default login"
#           then leave GOOGLE_APPLICATION_CREDENTIALS commented out below.
#
# Option B (for CI or peer reviewers without gcloud):
#           download a service account JSON key from GCP console,
#           save it as credentials.json in the project root,
#           then uncomment the line below.
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json